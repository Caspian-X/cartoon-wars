{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"godot-ai": {
			"url": "http://127.0.0.1:8000/mcp",
			"type": "remote",
			"enabled": true
		},
		// uv --directory ~/blender_mcp/mcp run blender-mcp --transport http --port 9191 &
		"blender-mcp": {
			"type": "remote",
			"url": "http://127.0.0.1:9191",
			"enabled": true
		}
	}
}
